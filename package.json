{
  "name": "mcp-kit",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.1",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "test": "rstest --passWithNoTests",
    "clean": "turbo run clean && rimraf node_modules",
    "readme": "turbo run readme --parallel",
    "docs:dev": "turbo run docs:dev",
    "docs:build": "turbo run docs:build"
  },
  "devDependencies": {
    "@rslint/core": "^0.5.3",
    "@rstest/core": "^0.10.3",
    "@rstest/coverage-v8": "^0.10.3",
    "@types/node": "^25.6.0",
    "bun": "^1.2.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jl917/mcp-kit.git"
  },
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.2"
  }
}
