{
  "name": "@julong/mono-rele2-utils",
  "version": "1.18.0",
  "description": "Use when the user needs text or object utilities, or to parse user data — covers: class name merging, case conversion (camel/snake/kebab/upper/lower/capitalize), text truncation, object flattening, environment variable lookup, and extracting name/city from RandomUser-format JSON (사용자 정보 분석). Accepts JSON strings or objects.",
  "license": "ISC",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "mono-rele2-utils": "./dist/server.js",
    "mono-rele2-utils-cli": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "rslint --config ../../rslint.config.ts .",
    "format": "prettier --write src/ --write '*.{ts,json,js}'",
    "format:check": "prettier --check src/ --check '*.{ts,json,js}'",
    "readme": "bun ../common/build/update-readme.mjs"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.2"
  }
}
